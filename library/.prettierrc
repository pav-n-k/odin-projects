{
    "singleQuote": true,
    "trailingComma": "none",
    "semi": true,
    "printWidth": 80,
    "tabWidth": 4,
    "useTabs": false,
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf",
    "quoteProps": "as-needed",
    "bracketSameLine": false,
    "htmlWhitespaceSensitivity": "css"
}
